<Page x:Class="WpfAppCarSharing.AUTH_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfAppCarSharing"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AUTH_Page"
      Background="Azure">

    <Grid Margin="10">
        <StackPanel Margin="10,100,10,10" >
            <TextBlock Text="Авторизация"  FontSize="24" Margin="-10,0,0,0"  
                                  Foreground="Aqua"  FontWeight="Bold" Width="160" Height="30" />
            <TextBlock Text="Логин:"   HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <TextBox x:Name="txtUsername" Height="30" Width="250" HorizontalAlignment="Center" Background="AliceBlue" BorderBrush="Gray" />

            <TextBlock Text="Пароль:"  HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <PasswordBox x:Name="txtPassword" Height="30" Width="250" HorizontalAlignment="Center"  Background="AliceBlue" BorderBrush="Gray"/>

            <Button x:Name="LoginButton" Content="войти"  FontWeight="Bold" Height="30" Width="130" 
                    Background="LightYellow" Foreground="Aqua" BorderBrush="Gray"
                
                           FontSize="14" IsDefault="True" Margin="0,10,0,5" 
                    
                    Click="LoginButton_Click"/>

        </StackPanel>
    </Grid>
</Page>
