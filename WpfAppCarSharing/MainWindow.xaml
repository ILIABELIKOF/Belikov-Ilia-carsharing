<Window x:Class="WpfAppCarSharing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppCarSharing"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800" Background="Azure">


    <Grid Margin="20">
       
       
        <StackPanel  Margin="110,110,110,110"  >
            <TextBlock Text="Пройдите Captcha" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold"/>
            <Image  Height="45" Width="150" />
            <TextBox  x:Name="Captcha" HorizontalAlignment="Center" Height="25" Width="150" BorderBrush="Gray" Background="AliceBlue" 
                      VerticalAlignment="Bottom" Margin="0,20,0,10"/>
        </StackPanel>


    </Grid>
</Window>
